generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String
  department       String?
  designation      String?
  phone   String?  @unique
  officeLocation   String?
  role             String   @default("user")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  passwordResetToken PasswordResetToken?
  refreshTokens      RefreshToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  otp       String
  expiresAt DateTime
}

model Adapter {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  releases  Release[]
  meetings  Meeting[]
}

model Release {
  id          String        @id @default(cuid())
  name        String
  adapterId   String
  adapter     Adapter       @relation(fields: [adapterId], references: [id], onDelete: Cascade)
  summary     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  enhancements Enhancement[]
  meetings    Meeting[]
  @@unique([name, adapterId])
}

model Enhancement {
  id        String    @id @default(cuid())
  name      String
  releaseId String
  release   Release   @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  meetings  Meeting[]
  @@unique([name, releaseId])
}

model Meeting {
  id                  String      @id @default(cuid())
  title               String
  adapterId           String
  releaseId           String
  enhancementId       String
  adapter             Adapter     @relation(fields: [adapterId], references: [id])
  release             Release     @relation(fields: [releaseId], references: [id])
  enhancement         Enhancement @relation(fields: [enhancementId], references: [id])
  transcriptUrl       String?
  transcriptText       String?  
  status              String      @default("pending") // pending, processing, completed, failed
  sharepointSyncStatus String     @default("pending")

  // AI generated content
  execSummary         String?     // Executive Summary text
  execMermaid         String?     // Executive Summary Mermaid script
  techSummary         String?     // Technical Summary text
  techMermaid         String?     // Technical Summary Mermaid script
  speakerSummary      String?     // Speaker Summary text
  speakerMermaid      String?     // Speaker Summary Mermaid script
  metadata            Json?       // meeting metadata (date, participants, agenda, etc.)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())
}